# HmanLab Environment Configuration
# Copy this file to .env and fill in your values.
#
# Required: At least one LLM provider and one channel.

# ═══════════════════════════════════════════════
# LLM Provider (pick one)
# ═══════════════════════════════════════════════

# Anthropic Claude (recommended)
HMANLAB_PROVIDERS_ANTHROPIC_API_KEY=

# OpenAI
# HMANLAB_PROVIDERS_OPENAI_API_KEY=

# OpenRouter (access multiple models)
# HMANLAB_PROVIDERS_OPENROUTER_API_KEY=

# ═══════════════════════════════════════════════
# Channels (pick one or more)
# ═══════════════════════════════════════════════

# Telegram Bot
HMANLAB_CHANNELS_TELEGRAM_BOT_TOKEN=

# Discord Bot
# HMANLAB_CHANNELS_DISCORD_TOKEN=

# Slack Bot
# HMANLAB_CHANNELS_SLACK_BOT_TOKEN=
# HMANLAB_CHANNELS_SLACK_APP_TOKEN=

# ═══════════════════════════════════════════════
# Optional: Tools
# ═══════════════════════════════════════════════

# Web Search (Brave Search API)
# BRAVE_API_KEY=

# WhatsApp Business
# HMANLAB_TOOLS_WHATSAPP_PHONE_NUMBER_ID=
# HMANLAB_TOOLS_WHATSAPP_ACCESS_TOKEN=

# Google Sheets
# HMANLAB_TOOLS_GOOGLE_SHEETS_ACCESS_TOKEN=

# ═══════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════
RUST_LOG=hmanlab=info
RUST_LOG_FORMAT=json
